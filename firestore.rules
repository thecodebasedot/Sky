rules_version = '2';

// Security rules for Sky's Cloud Firestore data.
// Deploy with:  firebase deploy --only firestore:rules
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // User profiles. Anyone signed in can read a profile (needed to render
    // chat participants); only the owner can write their own.
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Conversations. Only participants may read or write a chat document.
    match /chats/{chatId} {
      function isParticipant() {
        return isSignedIn()
          && request.auth.uid in resource.data.participantIds;
      }
      function willBeParticipant() {
        return isSignedIn()
          && request.auth.uid in request.resource.data.participantIds;
      }

      allow read: if isParticipant();
      // Create requires the creator to list themselves as a participant.
      allow create: if willBeParticipant();
      allow update, delete: if isParticipant();

      // Messages within a chat. Only participants of the parent chat may
      // read; a sender may only write messages authored by themselves.
      match /messages/{messageId} {
        function parentChat() {
          return get(/databases/$(database)/documents/chats/$(chatId)).data;
        }
        allow read: if isSignedIn()
          && request.auth.uid in parentChat().participantIds;
        allow create: if isSignedIn()
          && request.auth.uid in parentChat().participantIds
          && request.resource.data.senderId == request.auth.uid;
        allow update, delete: if isSignedIn()
          && resource.data.senderId == request.auth.uid;
      }
    }

    // Call signaling. Only the two parties may read/update the call doc; ICE
    // candidate subcollections are readable/writable by any signed-in user
    // (they're only useful to the matching call).
    match /calls/{callId} {
      allow read: if isSignedIn()
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId);
      allow create: if isSignedIn()
        && request.auth.uid == request.resource.data.callerId;
      allow update: if isSignedIn()
        && (request.auth.uid == resource.data.callerId
            || request.auth.uid == resource.data.calleeId);

      match /{candidateSet}/{candidateId} {
        allow read, write: if isSignedIn();
      }
    }
  }
}
